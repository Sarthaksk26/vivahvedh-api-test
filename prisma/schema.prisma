generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String           @id @default(uuid())
  regId                String           @unique
  email                String?          @unique
  mobile               String           @unique
  password             String
  role                 Role             @default(USER)
  accountStatus        AccountStatus    @default(INACTIVE)
  profileCreatedBy     String?
  requiresPasswordChange Boolean        @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  paymentDone          Boolean          @default(false)
  lastPaidOn           DateTime?
  planType             PlanType         @default(FREE)
  planExpiresAt        DateTime?
  images               Image[]
  pendingPayments      PendingPayment[]
  profileViewsReceived ProfileView[]    @relation("ViewedProfile")
  profileViewsSent     ProfileView[]    @relation("ViewerProfile")
  receivedRequests     Request[]        @relation("ReceivedRequests")
  sentRequests         Request[]        @relation("SentRequests")
  shortlistedBy        Shortlist[]      @relation("ShortlistedBy")
  shortlistedUsers     Shortlist[]      @relation("ShortlistedUsers")
  addresses            UserAddress[]
  astrology            UserAstrology?
  education            UserEducation?
  family               UserFamily?
  physical             UserPhysical?
  preferences          UserPreferences?
  profile              UserProfile?

  @@index([planType, createdAt(sort: Desc)])
  @@index([role, accountStatus])
}

model UserProfile {
  id            String        @id @default(uuid())
  userId        String        @unique
  firstName     String
  middleName    String?
  lastName      String
  gender        Gender
  maritalStatus MaritalStatus
  birthDateTime DateTime?
  birthPlace    String?
  aboutMe       String?
  religionId    Int?
  casteId       Int?
  subCasteId    Int?
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gender, maritalStatus, casteId])
  @@index([casteId])
}

model UserPhysical {
  id         String   @id @default(uuid())
  userId     String   @unique
  height     String?
  weight     Int?
  bloodGroup String?
  complexion String?
  health     String?
  disease    String?
  diet       String?
  smoke      Boolean?
  drink      Boolean?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAstrology {
  id        String  @id @default(uuid())
  userId    String  @unique
  gothra    String?
  rashi     String?
  nakshatra String?
  charan    String?
  nadi      String?
  gan       String?
  mangal    String?
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserEducation {
  id                 String  @id @default(uuid())
  userId             String  @unique
  qualificationId    Int?
  trade              String?
  college            String?
  jobBusiness        String?
  jobAddress         String?
  annualIncome       String?
  specialAchievement String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFamily {
  id                String  @id @default(uuid())
  userId            String  @unique
  fatherName        String?
  fatherOccupation  String?
  motherName        String?
  motherOccupation  String?
  motherHometown    String?
  maternalUncleName String?
  brothers          Int     @default(0)
  marriedBrothers   Int     @default(0)
  sisters           Int     @default(0)
  marriedSisters    Int     @default(0)
  relativesSirnames String?
  familyBackground  String?
  familyWealth      String?
  agricultureLand   String?
  plot              String?
  flat              String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreferences {
  id           String  @id @default(uuid())
  userId       String  @unique
  expectations String?
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserAddress {
  id          String  @id @default(uuid())
  userId      String
  addressType String
  addressLine String?
  city        String?
  district    String?
  state       String?
  talukaId    Int?
  districtId  Int?
  stateId     Int?
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Image {
  id        String   @id @default(uuid())
  userId    String
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Request {
  id         String        @id @default(uuid())
  senderId   String
  receiverId String
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  receiver   User          @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User          @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model Shortlist {
  id           String   @id @default(uuid())
  userId       String
  targetUserId String
  createdAt    DateTime @default(now())
  target       User     @relation("ShortlistedBy", fields: [targetUserId], references: [id], onDelete: Cascade)
  user         User     @relation("ShortlistedUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId])
}

model ProfileView {
  id       String   @id @default(uuid())
  viewerId String
  viewedId String
  viewedAt DateTime @default(now())
  viewed   User     @relation("ViewedProfile", fields: [viewedId], references: [id], onDelete: Cascade)
  viewer   User     @relation("ViewerProfile", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([viewerId, viewedId])
}

model Enquiry {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  email      String
  mobile     String
  subject    String
  message    String
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model PendingPayment {
  id            String        @id @default(uuid())
  userId        String
  planType      PlanType
  amount        Float
  screenshotUrl String
  transactionId String
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, transactionId])
}

model Religion {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model Caste {
  id         Int    @id @default(autoincrement())
  religionId Int?
  name       String
}

model SubCaste {
  id      Int    @id @default(autoincrement())
  casteId Int?
  name    String
}

model State {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model District {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model Taluka {
  id         Int    @id @default(autoincrement())
  districtId Int?
  name       String
}

model IncomeRange {
  id    Int    @id @default(autoincrement())
  range String @unique
}

model Qualification {
  id    Int     @id @default(autoincrement())
  name  String  @unique
  group String?
}

model Occupation {
  id   Int    @id @default(autoincrement())
  type String @unique
}

model SuccessStory {
  id          String      @id @default(uuid())
  groomName   String
  brideName   String
  message     String      @db.Text
  photoUrl    String?
  status      StoryStatus @default(PENDING)
  submittedBy String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum StoryStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  UNMARRIED
  DIVORCED
  WIDOWED
  SEPARATED
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlanType {
  FREE
  SILVER
  GOLD
}
